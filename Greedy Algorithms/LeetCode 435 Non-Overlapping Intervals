// Problem: Non-Overlapping Intervals
// Platform: LeetCode 435
// Pattern: Greedy (Interval Scheduling)
//
// Problem Statement:
// Given an array of intervals, return the minimum number of intervals
// you need to remove to make the rest of the intervals non-overlapping.
//
// ------------------------------------------------------------
// 🔑 Greedy Idea:
// Always keep the interval which ends earliest.
//
// Why?
// → It leaves maximum space for future intervals
// → Minimizes overlaps
//
// ------------------------------------------------------------
// 🔧 Sorting Explanation:
//
// sort(intervals.begin(), intervals.end(),
//      [](auto &a, auto &b){
//          return a[1] < b[1];
//      });
//
// Here:
// a = [start1, end1]
// b = [start2, end2]
//
// Comparator meaning:
// → If a[1] < b[1], then a comes before b
// → Sorting is done based on END TIME
//
// Example:
// Input:  [1,2], [2,3], [1,3]
// Sorted: [1,2], [2,3], [1,3]
//
// ------------------------------------------------------------
// ⚙️ Greedy Flow:
//
// 1. Pick first interval
// 2. Compare next interval:
//      if(start < prevEnd) → overlap → remove it
//      else → take it and update prevEnd
//
// ------------------------------------------------------------
// ⏱️ Time Complexity:
// Sorting: O(n log n)
// Loop:    O(n)
// Total:   O(n log n)
//
// 💾 Space Complexity:
// O(1)
//
// ------------------------------------------------------------

#include <bits/stdc++.h>
using namespace std;

class Solution {
public:

/////////////////////////////////////////////////////////
// Greedy (Optimal Solution)
/////////////////////////////////////////////////////////

    int eraseOverlapIntervals(vector<vector<int>>& intervals){

        // Step 1: Sort by ending time
        sort(intervals.begin(), intervals.end(),
             [](auto &a, auto &b){
                 return a[1] < b[1];
             });

        int cnt = 0;

        // Step 2: Take first interval
        int prevEnd = intervals[0][1];

        // Step 3: Traverse remaining intervals
        for(int i = 1; i < intervals.size(); i++){

            // Overlapping case
            if(intervals[i][0] < prevEnd){
                cnt++; // remove interval
            }
            else{
                // Non-overlapping → take it
                prevEnd = intervals[i][1];
            }
        }

        return cnt;
    }
};

/////////////////////////////////////////////////////////
// Driver Code
/////////////////////////////////////////////////////////

int main(){

    vector<vector<int>> intervals = {
        {1,2}, {2,3}, {3,4}, {1,3}
    };

    cout<<"Intervals: ";
    for(auto &it : intervals)
        cout<<"["<<it[0]<<","<<it[1]<<"] ";

    cout<<endl;

    Solution sol;

    cout<<"Minimum intervals to remove: "
        <<sol.eraseOverlapIntervals(intervals)<<endl;

    return 0;
}
