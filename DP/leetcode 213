// Problem: House Robber II (Circular Houses)
// Platform: LeetCode 213
//
// Idea:
// Since houses are circular, first and last cannot be robbed together.
// So solve two linear cases:
// 1. Exclude first house
// 2. Exclude last house
//
// Time Complexity: O(n)
// Space Complexity: O(1)

#include <bits/stdc++.h>
using namespace std;

///////////////////////////////////////////////////////////
// 🔹 Linear House Robber (Space Optimized)
///////////////////////////////////////////////////////////
long long solve(vector<int>& arr) {

    int n = arr.size();

    if (n == 1)
        return arr[0];

    long long prev = arr[0];
    long long prev2 = 0;

    for (int i = 1; i < n; i++) {

        long long pick = arr[i];
        if (i > 1)
            pick += prev2;

        long long notPick = prev;

        long long curr = max(pick, notPick);

        prev2 = prev;
        prev = curr;
    }

    return prev;
}

///////////////////////////////////////////////////////////
// 🔹 Circular House Robber
///////////////////////////////////////////////////////////
long long robStreet(int n, vector<int> &arr) {

    if (n == 0) return 0;
    if (n == 1) return arr[0];

    vector<int> arr1, arr2;

    // Exclude first house
    for (int i = 1; i < n; i++)
        arr1.push_back(arr[i]);

    // Exclude last house
    for (int i = 0; i < n - 1; i++)
        arr2.push_back(arr[i]);

    long long ans1 = solve(arr1);
    long long ans2 = solve(arr2);

    return max(ans1, ans2);
}

///////////////////////////////////////////////////////////
// 🔥 Driver Code
///////////////////////////////////////////////////////////
int main() {

    vector<int> arr = {1,5,1,2,6};
    int n = arr.size();

    cout << "Maximum loot: "
         << robStreet(n, arr) << endl;

    return 0;
}
