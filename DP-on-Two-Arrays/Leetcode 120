// Problem: Triangle Minimum Path Sum
// Platform: LeetCode 120
//
// Approaches:
// 1. Recursion
// 2. Memoization
// 3. Tabulation
// 4. Space Optimized DP

#include <bits/stdc++.h>
using namespace std;

class Solution {
public:

/////////////////////////////////////////////////////////
// 1️⃣ Recursion
/////////////////////////////////////////////////////////
int recursion(int i,int j,int m,vector<vector<int>>&triangle){

    if(i==m-1) return triangle[m-1][j];

    int down = triangle[i][j] +
               recursion(i+1,j,m,triangle);

    int diag = triangle[i][j] +
               recursion(i+1,j+1,m,triangle);

    return min(down,diag);
}

/////////////////////////////////////////////////////////
// 2️⃣ Memoization
/////////////////////////////////////////////////////////
int memo(int i,int j,int m,
         vector<vector<int>>&triangle,
         vector<vector<int>>&dp){

    if(i==m-1) return triangle[m-1][j];

    if(dp[i][j]!=-1) return dp[i][j];

    int down = triangle[i][j] +
               memo(i+1,j,m,triangle,dp);

    int diag = triangle[i][j] +
               memo(i+1,j+1,m,triangle,dp);

    return dp[i][j] = min(down,diag);
}

/////////////////////////////////////////////////////////
// 3️⃣ Tabulation
/////////////////////////////////////////////////////////
int tabulation(vector<vector<int>>&triangle){

    int m = triangle.size();

    vector<vector<int>> dp(m,vector<int>(m,0));

    for(int j=0;j<m;j++)
        dp[m-1][j] = triangle[m-1][j];

    for(int i=m-2;i>=0;i--){

        for(int j=0;j<=i;j++){

            int down = triangle[i][j] + dp[i+1][j];
            int diag = triangle[i][j] + dp[i+1][j+1];

            dp[i][j] = min(down,diag);
        }
    }

    return dp[0][0];
}

/////////////////////////////////////////////////////////
// 4️⃣ Space Optimized
/////////////////////////////////////////////////////////
int spaceOptimized(vector<vector<int>>&triangle){

    int m = triangle.size();

    vector<int> front(m);

    for(int j=0;j<m;j++)
        front[j] = triangle[m-1][j];

    vector<int> curr(m);

    for(int i=m-2;i>=0;i--){

        for(int j=0;j<=i;j++){

            int down = triangle[i][j] + front[j];
            int diag = triangle[i][j] + front[j+1];

            curr[j] = min(down,diag);
        }

        front = curr;
    }

    return front[0];
}

};

/////////////////////////////////////////////////////////
// Driver Code
/////////////////////////////////////////////////////////
int main(){

    vector<vector<int>> triangle = {
        {2},
        {3,4},
        {6,5,7},
        {4,1,8,3}
    };

    Solution sol;

    cout<<"Recursion: "
        <<sol.recursion(0,0,
        triangle.size(),triangle)<<endl;

    vector<vector<int>> dp(triangle.size(),
        vector<int>(triangle.size(),-1));

    cout<<"Memoization: "
        <<sol.memo(0,0,
        triangle.size(),triangle,dp)<<endl;

    cout<<"Tabulation: "
        <<sol.tabulation(triangle)<<endl;

    cout<<"Space Optimized: "
        <<sol.spaceOptimized(triangle)<<endl;

    return 0;
}
