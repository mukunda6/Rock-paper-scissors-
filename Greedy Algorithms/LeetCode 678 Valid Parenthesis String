// Problem: Valid Parenthesis String
// Platform: LeetCode 678
// Pattern: Greedy + Recursion
//
// Problem Statement:
// Given a string s containing '(', ')' and '*',
// return true if the string is valid.
// '*' can be:
//   → '('
//   → ')'
//   → empty
//
// ------------------------------------------------------------
// Approaches:
// 1. Recursion (Brute Force)
// 2. Greedy (Optimal)
//
// ------------------------------------------------------------
// ⏱️ Time Complexity:
// Recursion: O(3^n)
// Greedy: O(n)
//
// 💾 Space Complexity:
// Recursion: O(n)
// Greedy: O(1)
//
// ------------------------------------------------------------

#include <bits/stdc++.h>
using namespace std;

class Solution {
public:

/////////////////////////////////////////////////////////
// 1️⃣ Recursion (Brute Force)
/////////////////////////////////////////////////////////

    bool isvalid(string &s, int idx, int cnt){

        // invalid if more closing brackets
        if(cnt < 0) return false;

        // reached end → valid if balanced
        if(idx == s.size())
            return cnt == 0;

        if(s[idx] == '('){
            return isvalid(s, idx+1, cnt+1);
        }
        else if(s[idx] == ')'){
            return isvalid(s, idx+1, cnt-1);
        }
        else{ // '*'
            return isvalid(s, idx+1, cnt)     // empty
                || isvalid(s, idx+1, cnt+1)  // '('
                || isvalid(s, idx+1, cnt-1); // ')'
        }
    }

    bool recursion(string s){
        return isvalid(s, 0, 0);
    }

/////////////////////////////////////////////////////////
// 2️⃣ Greedy (Optimal)
/////////////////////////////////////////////////////////

    bool greedy(string s){

        int minOpen = 0;
        int maxOpen = 0;

        for(char c : s){

            if(c == '('){
                minOpen++;
                maxOpen++;
            }
            else if(c == ')'){
                minOpen--;
                maxOpen--;
            }
            else{ // '*'
                minOpen--;
                maxOpen++;
            }

            if(maxOpen < 0)
                return false;

            if(minOpen < 0)
                minOpen = 0;
        }

        return minOpen == 0;
    }
};

/////////////////////////////////////////////////////////
// Driver Code
/////////////////////////////////////////////////////////

int main(){

    string s = "(*))";

    cout<<"String: "<<s<<endl;

    Solution sol;

    cout<<"Recursion: "<<sol.recursion(s)<<endl;

    cout<<"Greedy (Optimal): "<<sol.greedy(s)<<endl;

    return 0;
}
