// Problem: Partition Equal Subset Sum
// Platform: LeetCode 416
//
// Approaches:
// 1. Recursion
// 2. Memoization
// 3. Tabulation
// 4. Space Optimized DP

#include <bits/stdc++.h>
using namespace std;

class Solution {
public:

/////////////////////////////////////////////////////////
// 1️⃣ Recursion
// Time Complexity: O(2^n)
// Space Complexity: O(n)
/////////////////////////////////////////////////////////

bool recursion(int idx,int target,vector<int>&nums){

    if(target==0) return true;

    if(idx==0) return nums[0]==target;

    bool nottake = recursion(idx-1,target,nums);

    bool take = false;

    if(nums[idx]<=target)
        take = recursion(idx-1,target-nums[idx],nums);

    return take || nottake;
}

/////////////////////////////////////////////////////////
// 2️⃣ Memoization
// Time Complexity: O(n * target)
// Space Complexity: O(n * target)
/////////////////////////////////////////////////////////

bool memo(int idx,int target,vector<int>&nums,vector<vector<int>>&dp){

    if(target==0) return true;

    if(idx==0) return nums[0]==target;

    if(dp[idx][target]!=-1)
        return dp[idx][target];

    bool nottake = memo(idx-1,target,nums,dp);

    bool take = false;

    if(nums[idx]<=target)
        take = memo(idx-1,target-nums[idx],nums,dp);

    return dp[idx][target] = take || nottake;
}

/////////////////////////////////////////////////////////
// 3️⃣ Tabulation
// Time Complexity: O(n * target)
// Space Complexity: O(n * target)
/////////////////////////////////////////////////////////

bool tabulation(vector<int>&nums){

    int n = nums.size();

    int sum = 0;

    for(int x:nums) sum += x;

    if(sum%2) return false;

    int target = sum/2;

    vector<vector<bool>> dp(n,vector<bool>(target+1,false));

    for(int i=0;i<n;i++)
        dp[i][0] = true;

    if(nums[0]<=target)
        dp[0][nums[0]] = true;

    for(int i=1;i<n;i++){

        for(int t=1;t<=target;t++){

            bool nottake = dp[i-1][t];

            bool take = false;

            if(nums[i]<=t)
                take = dp[i-1][t-nums[i]];

            dp[i][t] = take || nottake;
        }
    }

    return dp[n-1][target];
}

/////////////////////////////////////////////////////////
// 4️⃣ Space Optimized
// Time Complexity: O(n * target)
// Space Complexity: O(target)
/////////////////////////////////////////////////////////

bool spaceOptimized(vector<int>&nums){

    int n = nums.size();

    int sum = 0;

    for(int x:nums) sum += x;

    if(sum%2) return false;

    int target = sum/2;

    vector<bool> prev(target+1,false);
    vector<bool> curr(target+1,false);

    prev[0] = curr[0] = true;

    if(nums[0]<=target)
        prev[nums[0]] = true;

    for(int i=1;i<n;i++){

        for(int t=1;t<=target;t++){

            bool nottake = prev[t];

            bool take = false;

            if(nums[i]<=t)
                take = prev[t-nums[i]];

            curr[t] = take || nottake;
        }

        prev = curr;
    }

    return prev[target];
}

};

/////////////////////////////////////////////////////////
// Driver Code
/////////////////////////////////////////////////////////

int main(){

    vector<int> nums = {1,5,11,5};

    Solution sol;

    int sum = 0;

    for(int x:nums) sum += x;

    if(sum%2){
        cout<<"Recursion: 0"<<endl;
        cout<<"Memoization: 0"<<endl;
        cout<<"Tabulation: 0"<<endl;
        cout<<"Space Optimized: 0"<<endl;
        return 0;
    }

    int target = sum/2;

    cout<<"Recursion: "<<sol.recursion(nums.size()-1,target,nums)<<endl;

    vector<vector<int>> dp(nums.size(),vector<int>(target+1,-1));

    cout<<"Memoization: "<<sol.memo(nums.size()-1,target,nums,dp)<<endl;

    cout<<"Tabulation: "<<sol.tabulation(nums)<<endl;

    cout<<"Space Optimized: "<<sol.spaceOptimized(nums)<<endl;

    return 0;
}
