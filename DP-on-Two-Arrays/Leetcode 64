// Problem: Minimum Path Sum
// Platform: LeetCode 64
//
// Approaches:
// 1. Recursion
// 2. Memoization
// 3. Tabulation
// 4. Space Optimized

#include <bits/stdc++.h>
using namespace std;

class Solution {
public:

/////////////////////////////////////////////////////////
// 1️⃣ Recursion
/////////////////////////////////////////////////////////
int recursion(int i,int j,vector<vector<int>>&grid){

    if(i==0 && j==0) return grid[0][0];
    if(i<0 || j<0) return INT_MAX;

    int up = recursion(i-1,j,grid);
    int left = recursion(i,j-1,grid);

    int ans = min(up,left);

    if(ans==INT_MAX) return INT_MAX;

    return grid[i][j] + ans;
}

/////////////////////////////////////////////////////////
// 2️⃣ Memoization
/////////////////////////////////////////////////////////
int memo(int i,int j,vector<vector<int>>&grid,
         vector<vector<int>>&dp){

    if(i==0 && j==0) return grid[0][0];
    if(i<0 || j<0) return 1e9;

    if(dp[i][j]!=-1) return dp[i][j];

    int up = grid[i][j] + memo(i-1,j,grid,dp);
    int left = grid[i][j] + memo(i,j-1,grid,dp);

    return dp[i][j] = min(up,left);
}

/////////////////////////////////////////////////////////
// 3️⃣ Tabulation
/////////////////////////////////////////////////////////
int tabulation(vector<vector<int>>&grid){

    int m = grid.size();
    int n = grid[0].size();

    vector<vector<int>>dp(m,vector<int>(n,0));

    for(int i=0;i<m;i++){
        for(int j=0;j<n;j++){

            if(i==0 && j==0){
                dp[i][j] = grid[i][j];
            }
            else{

                int up = grid[i][j];
                if(i>0) up += dp[i-1][j];
                else up += 1e9;

                int left = grid[i][j];
                if(j>0) left += dp[i][j-1];
                else left += 1e9;

                dp[i][j] = min(up,left);
            }
        }
    }

    return dp[m-1][n-1];
}

/////////////////////////////////////////////////////////
// 4️⃣ Space Optimized
/////////////////////////////////////////////////////////
int spaceOptimized(vector<vector<int>>&grid){

    int m = grid.size();
    int n = grid[0].size();

    vector<int> prev(n,0);

    for(int i=0;i<m;i++){

        vector<int> curr(n,0);

        for(int j=0;j<n;j++){

            if(i==0 && j==0){
                curr[j] = grid[i][j];
            }
            else{

                int up = grid[i][j];
                if(i>0) up += prev[j];
                else up += 1e9;

                int left = grid[i][j];
                if(j>0) left += curr[j-1];
                else left += 1e9;

                curr[j] = min(up,left);
            }
        }

        prev = curr;
    }

    return prev[n-1];
}

};

/////////////////////////////////////////////////////////
// Driver Code
/////////////////////////////////////////////////////////
int main(){

    vector<vector<int>> grid = {
        {1,3,1},
        {1,5,1},
        {4,2,1}
    };

    Solution sol;

    cout<<"Recursion: "
        <<sol.recursion(grid.size()-1,
                        grid[0].size()-1,
                        grid)<<endl;

    vector<vector<int>>dp(grid.size(),
        vector<int>(grid[0].size(),-1));

    cout<<"Memoization: "
        <<sol.memo(grid.size()-1,
                   grid[0].size()-1,
                   grid,dp)<<endl;

    cout<<"Tabulation: "
        <<sol.tabulation(grid)<<endl;

    cout<<"Space Optimized: "
        <<sol.spaceOptimized(grid)<<endl;

    return 0;
}
