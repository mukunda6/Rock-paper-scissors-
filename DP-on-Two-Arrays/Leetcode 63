// Problem: Unique Paths II
// Platform: LeetCode 63
//
// Approaches:
// 1. Recursion
// 2. Memoization
// 3. Tabulation
// 4. Space Optimized

#include <bits/stdc++.h>
using namespace std;

class Solution {
public:

/////////////////////////////////////////////////////////
// 1️⃣ Recursion
/////////////////////////////////////////////////////////
int recursion(int i,int j,vector<vector<int>>& grid){

    if(i<0 || j<0) return 0;
    if(grid[i][j]==1) return 0;
    if(i==0 && j==0) return 1;

    int up = recursion(i-1,j,grid);
    int left = recursion(i,j-1,grid);

    return up + left;
}

/////////////////////////////////////////////////////////
// 2️⃣ Memoization
/////////////////////////////////////////////////////////
int memo(int i,int j,vector<vector<int>>& grid,
         vector<vector<int>>& dp){

    if(i<0 || j<0) return 0;
    if(grid[i][j]==1) return 0;
    if(i==0 && j==0) return 1;

    if(dp[i][j]!=-1) return dp[i][j];

    int up = memo(i-1,j,grid,dp);
    int left = memo(i,j-1,grid,dp);

    return dp[i][j] = up + left;
}

/////////////////////////////////////////////////////////
// 3️⃣ Tabulation
/////////////////////////////////////////////////////////
int tabulation(vector<vector<int>>& grid){

    int m = grid.size();
    int n = grid[0].size();

    vector<vector<int>> dp(m, vector<int>(n,0));

    for(int i=0;i<m;i++){
        for(int j=0;j<n;j++){

            if(grid[i][j]==1){
                dp[i][j]=0;
                continue;
            }

            if(i==0 && j==0){
                dp[i][j]=1;
                continue;
            }

            int up=0,left=0;

            if(i>0) up=dp[i-1][j];
            if(j>0) left=dp[i][j-1];

            dp[i][j]=up+left;
        }
    }

    return dp[m-1][n-1];
}

/////////////////////////////////////////////////////////
// 4️⃣ Space Optimized
/////////////////////////////////////////////////////////
int spaceOptimized(vector<vector<int>>& grid){

    int m = grid.size();
    int n = grid[0].size();

    vector<int> prev(n,0);

    for(int i=0;i<m;i++){

        vector<int> curr(n,0);

        for(int j=0;j<n;j++){

            if(grid[i][j]==1){
                curr[j]=0;
                continue;
            }

            if(i==0 && j==0){
                curr[j]=1;
                continue;
            }

            int up=0,left=0;

            if(i>0) up=prev[j];
            if(j>0) left=curr[j-1];

            curr[j]=up+left;
        }

        prev = curr;
    }

    return prev[n-1];
}

};

/////////////////////////////////////////////////////////
// Driver Code
/////////////////////////////////////////////////////////
int main(){

    vector<vector<int>> grid = {
        {0,0,0},
        {0,1,0},
        {0,0,0}
    };

    Solution sol;

    cout<<"Recursion: "
        <<sol.recursion(grid.size()-1,
                        grid[0].size()-1,
                        grid)<<endl;

    vector<vector<int>> dp(grid.size(),
            vector<int>(grid[0].size(),-1));

    cout<<"Memoization: "
        <<sol.memo(grid.size()-1,
                   grid[0].size()-1,
                   grid,dp)<<endl;

    cout<<"Tabulation: "
        <<sol.tabulation(grid)<<endl;

    cout<<"Space Optimized: "
        <<sol.spaceOptimized(grid)<<endl;

    return 0;
}
